rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /siteConfig/events {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasAll(['recurringEvents', 'specialEvents'])
        && request.resource.data.recurringEvents is list
        && request.resource.data.specialEvents is list;
    }
  }
}
